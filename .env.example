# Copie para .env.local e preencha (não commite .env.local)

# URL pública do app (ajuda Stripe checkout/portal quando o header Origin não vem)
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_publica

# Acesso: trial automático = data de criação da conta + APP_TRIAL_DAYS (sem cartão).
# Depois: assinatura Stripe (padrão) OU cobrança PAID na AbacatePay — ver APP_PAYMENT_PROVIDER abaixo.
APP_TRIAL_DAYS=7
# APP_PAYWALL_DISABLED=false

# Pagamento que libera o app: stripe (padrão) | abacatepay (só AbacatePay no paywall + Planos)
# Guia: docs/PAGAMENTO_STRIPE_OU_ABACATEPAY.md — reinicie npm run dev após alterar.
# Produção: mantenha Stripe ativo (checkout + portal). Só use abacatepay se quiser paywall só via AbacatePay.
APP_PAYMENT_PROVIDER=stripe

# Stripe — use chaves de TESTE (sk_test_...) em dev
# Obtenha em: Dashboard → Developers → API keys (modo teste)
# Se a chave vazou em chat/repo: revogue e crie outra no mesmo painel
STRIPE_SECRET_KEY=
# IDs devem ser price_... (não prod_...)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_LIFETIME=

# AbacatePay – PIX e Cartão (Bearer token)
ABACATEPAY_TOKEN=
# ID de um cliente já existente na AbacatePay (ex.: cust_...), usado quando o checkout
# não envia CPF/celular. Crie o cliente no painel ou via POST /v1/customer/create e liste em GET /v1/customer/list
# ABACATEPAY_DEFAULT_CUSTOMER_ID=
#
# Produtos cadastrados na loja AbacatePay (painel → Produtos → ID tipo prod_...).
# Se definido, o checkout usa API v2 /checkouts/create com esse item (preço/descrição vêm do produto na loja).
# Chave de API precisa de permissão CHECKOUT:CREATE (v2).
# ABACATEPAY_STORE_PRODUCT_ID_PRO=
# ABACATEPAY_STORE_PRODUCT_ID_LIFETIME=
#
# Se sua chave é só API v1: true = ignora prod_ acima e usa só billing v1 (exige ABACATEPAY_DEFAULT_CUSTOMER_ID).
# ABACATEPAY_USE_V1_BILLING_ONLY=false
#
# Opcional: IDs prod_... separados por vírgula para mapear plano Pro/Business ao listar cobranças (modo APP_PAYMENT_PROVIDER=abacatepay)
# ABACATEPAY_ACCESS_PRO_PRODUCT_IDS=
# ABACATEPAY_ACCESS_BUSINESS_PRODUCT_IDS=
