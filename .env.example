# Copie para .env.local e preencha (não commite .env.local)

# URL pública do app (ajuda Stripe checkout/portal quando o header Origin não vem)
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_publica

# Acesso: trial automático = data de criação da conta + APP_TRIAL_DAYS (sem cartão).
# Depois só continua com assinatura Stripe ativa. Para desligar o bloqueio (ex.: migração): true
APP_TRIAL_DAYS=7
# APP_PAYWALL_DISABLED=false

# Stripe — use chaves de TESTE (sk_test_...) em dev
# Obtenha em: Dashboard → Developers → API keys (modo teste)
# Se a chave vazou em chat/repo: revogue e crie outra no mesmo painel
STRIPE_SECRET_KEY=
# IDs devem ser price_... (não prod_...)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_LIFETIME=

# AbacatePay – PIX e Cartão (Bearer token)
ABACATEPAY_TOKEN=
