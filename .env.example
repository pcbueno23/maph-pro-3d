# Copie para .env.local e preencha (não commite .env.local)
# Use sempre KEY=valor sem espaços em torno do = (senão o Next pode não carregar a variável).

# URL pública do app (ajuda Stripe checkout/portal quando o header Origin não vem)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Iframe na página /precificacao-marketplaces: URLs públicas das calculadoras já deployadas (rota /app de cada Vite app).
# O código das calculadoras não precisa ser alterado; se o iframe ficar em branco, libere frame-ancestors no host delas para o domínio do SaaS.
# Ex.: https://seu-ml.vercel.app/app  e  https://sua-shopee.vercel.app/app
NEXT_PUBLIC_CALC_ML_APP_URL=
NEXT_PUBLIC_CALC_SHOPEE_APP_URL=

# Google Ads (tag de conversão — IDs públicos, pode commitar)
NEXT_PUBLIC_GADS_ID=AW-18057816367
NEXT_PUBLIC_GADS_CONVERSION=AW-18057816367/7558513888

# Suporte — link curto WhatsApp (w.app). Padrão no código: https://w.app/maphpro3d
# NEXT_PUBLIC_WHATSAPP_SUPPORT_LINK=https://w.app/maphpro3d
# Opcional: número só para exibição na página (wa.me alternativo usa isso + mensagem)
# NEXT_PUBLIC_WHATSAPP_SUPPORT=5511999999999
# NEXT_PUBLIC_WHATSAPP_SUPPORT_MESSAGE=Olá! Preciso de ajuda com o MAPH PRO 3D.

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_publica

# Painel /admin: e-mails separados por vírgula (acesso a /api/admin/* e edição de trial por usuário).
# SUPABASE_SERVICE_ROLE_KEY = chave "service_role" em Supabase → Settings → API (só servidor; nunca NEXT_PUBLIC_).
ADMIN_EMAILS=
SUPABASE_SERVICE_ROLE_KEY=

# Acesso: trial automático = data de criação da conta + APP_TRIAL_DAYS (sem cartão).
# Depois: assinatura Stripe (padrão) OU cobrança PAID na AbacatePay — ver APP_PAYMENT_PROVIDER abaixo.
APP_TRIAL_DAYS=7
# APP_PAYWALL_DISABLED=false

# Pagamento que libera o app: stripe (padrão) | abacatepay (só AbacatePay no paywall + Planos)
# Guia: docs/PAGAMENTO_STRIPE_OU_ABACATEPAY.md e docs/ABACATEPAY.md — reinicie npm run dev após alterar.
# Exemplo só AbacatePay: APP_PAYMENT_PROVIDER=abacatepay (+ ABACATEPAY_TOKEN e cust_ — ver docs/ABACATEPAY.md)
# Opcional: mesmo valor que APP_PAYMENT_PROVIDER (só afeta bundle cliente). Em /pricing o servidor já envia o provedor (Vercel: basta APP_PAYMENT_PROVIDER).
# NEXT_PUBLIC_APP_PAYMENT_PROVIDER=abacatepay
APP_PAYMENT_PROVIDER=stripe

# Stripe — em dev use sk_test_... + preços criados no modo Teste do Dashboard
# Em produção (Vercel): sk_live_... + price_... criados no modo Live (não misturar)
# Guia: docs/STRIPE_MODO_PRODUCAO.md
STRIPE_SECRET_KEY=
# IDs devem ser price_... (não prod_...)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_LIFETIME=

# AbacatePay – PIX e Cartão (Bearer token)
ABACATEPAY_TOKEN=
# Opcional: cust_... só se o checkout NÃO enviar nome+CPF/CNPJ+celular (ex.: sandbox). Em produção o app
# coleta pagador na página Planos — pode omitir. LIVE: mesmo token = mesmo cust_ da conta live.
# ABACATEPAY_DEFAULT_CUSTOMER_ID=cust_
#
# Produtos da loja AbacatePay (painel → Produtos → ID prod_...). Plano Pro mensal e plano anual:
# ABACATEPAY_STORE_PRODUCT_ID_PRO=prod_...
# ABACATEPAY_STORE_PRODUCT_ID_LIFETIME=prod_...
# Com ambos definidos, o checkout usa só API v2 (preço/nome do painel). Chave: v2 + CHECKOUT:CREATE.
# Sem essas linhas (ou com USE_V1_BILLING_ONLY=true), usa billing v1 com preço fixo no código.
#
# Logotipo (opcional): por padrão o app usa NEXT_PUBLIC_APP_URL ou a origem do request + /logo.png (public/logo.png).
# Só precisa disto se quiser outra URL: https público acessível pela AbacatePay.
# ABACATEPAY_CHECKOUT_PRODUCT_IMAGE_URL=https://seu-dominio.com/logo.png
# ABACATEPAY_CHECKOUT_PRODUCT_IMAGE_URL_PRO=
# ABACATEPAY_CHECKOUT_PRODUCT_IMAGE_URL_LIFETIME=
# Se a AbacatePay retornar erro ao criar cobrança por causa dos campos de imagem: true
# ABACATEPAY_CHECKOUT_SKIP_PRODUCT_IMAGE=false
#
# Se sua chave é só API v1: true = ignora prod_ acima e usa só billing v1 (exige ABACATEPAY_DEFAULT_CUSTOMER_ID).
# ABACATEPAY_USE_V1_BILLING_ONLY=false
#
# Opcional: IDs prod_... separados por vírgula para mapear plano Pro/Business ao listar cobranças (modo APP_PAYMENT_PROVIDER=abacatepay)
# ABACATEPAY_ACCESS_PRO_PRODUCT_IDS=
# ABACATEPAY_ACCESS_BUSINESS_PRODUCT_IDS=
